{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "INFRA_BUILD_TESTS": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "base-debug",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "base-release",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug-ninja",
      "displayName": "Linux Debug (Ninja)",
      "inherits": "base-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug-ninja"
    },
    {
      "name": "linux-release-ninja",
      "displayName": "Linux Release (Ninja)",
      "inherits": "base-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-release-ninja"
    },
    {
      "name": "linux-debug-make",
      "displayName": "Linux Debug (Makefile)",
      "inherits": "base-debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-debug-make"
    },
    {
      "name": "linux-release-make",
      "displayName": "Linux Release (Makefile)",
      "inherits": "base-release",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/linux-release-make"
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug-ninja",
      "configurePreset": "linux-debug-ninja"
    },
    {
      "name": "linux-release-ninja",
      "configurePreset": "linux-release-ninja"
    },
    {
      "name": "linux-debug-make",
      "configurePreset": "linux-debug-make"
    },
    {
      "name": "linux-release-make",
      "configurePreset": "linux-release-make"
    }
  ]
}