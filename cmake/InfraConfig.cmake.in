# InfraConfig.cmake.in - Package configuration template (generated at install time)
# Defines imported targets and convenience variables for find_package(Infra)

@PACKAGE_INIT@

get_filename_component(INFRA_CMAKE_DIR "${CMAKE_CURRENT_LIST_DIR}" ABSOLUTE)
list(APPEND CMAKE_MODULE_PATH ${INFRA_CMAKE_DIR})

# Import all installed targets
include("${INFRA_CMAKE_DIR}/infra-targets.cmake" OPTIONAL)

# Set version and include paths
set(INFRA_VERSION "@INFRA_VERSION_STRING@")
set(INFRA_INCLUDE_DIRS "@PACKAGE_INFRA_INCLUDE_DIR@")

# Collect all module libraries
set(INFRA_LIBRARIES "")
foreach(MODULE @INFRA_MODULES@)
    if(TARGET infra::${MODULE})
        list(APPEND INFRA_LIBRARIES infra::${MODULE})
    endif()
endforeach()

# Verify required components
check_required_components(infra)